generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum RoomStatus {
  WAITING
  GAME_PHASE
  AFTERMATH
}

model Room {
  id                String       @id @default(cuid())
  status            RoomStatus   @default(WAITING)
  maxPlayers        Int          @default(4) // See shared/src/index.ts MAX_PLAYERS
  currentPhaseRound Int          @default(1)
  createdAt         DateTime     @default(now())
  // Host-toggled — excludes the room from Quick Play matching and the Available
  // Rooms list, but never blocks a direct room-code/invite-link join.
  inviteOnly        Boolean      @default(false)

  players           Player[]
  legalCaseHistory  LegalCaseHistory[]

  @@index([status])
  @@index([createdAt])
  @@index([id, currentPhaseRound])
}

model Player {
  id              String     @id @default(cuid())
  name            String
  roomId          String
  room            Room       @relation(fields: [roomId], references: [id], onDelete: Cascade)
  isHost          Boolean    @default(false)
  bankrupt        Boolean    @default(false)
  // Round this player was eliminated in (natural bankruptcy, merger/takeover, or
  // voluntary forfeit) — null while still active. Nothing else durably records
  // "when" a player went bankrupt; needed to reconstruct elimination timing for the
  // game-timeline replay/spectator feature without relying on live broadcasts alone.
  eliminatedRound Int?
  socketId        String?
  createdAt       DateTime   @default(now())
  companyId       String?    @unique
  company         Company?
  kpiSnapshots    KpiSnapshot[]

  @@index([roomId])
  @@index([roomId, bankrupt])
  @@index([socketId])
}

// One row per player per round — the source of the KPI history graphs (GamePhase's
// KPI cards + breakdown sub-items are all clickable, per CLAUDE.md's "KPI history +
// prediction graphs" section). Stores the same variables/derived/riskGauge shape the
// `turn:resolved` broadcast already carries per player, verbatim — deliberately not
// narrowed to a handful of named columns, so any current or future clickable field
// (cash, equity, revenue, operatingExpenses, staffCost, ...) can be graphed without a
// further migration. Written once per round from GameEngine.resolveGameTurn (and once
// for round 1 from broadcastInitialSnapshot) — never read/written by GameLoop itself,
// which stays pure; this is persistence, the same split as Company.
model KpiSnapshot {
  id        String   @id @default(cuid())
  playerId  String
  player    Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)
  round     Int
  variables Json
  derived   Json
  riskGauge Float
  createdAt DateTime @default(now())

  @@unique([playerId, round])
  @@index([playerId])
}

// ============================================================
// Company — financial & production variables (all stored as JSONB
// for flexibility; the game engine reads/writes them directly).
// Legacy columns (cash, debt) kept for quick queries.
// Engine state (active decisions, depreciation ledger, legal cases,
// share holdings) is stored in the `engineState` JSONB field.
// ============================================================
model Company {
  id                    String    @id @default(cuid())
  playerId              String    @unique
  player                Player    @relation(fields: [playerId], references: [id], onDelete: Cascade)
  cash                  Decimal   @default(100000) @db.Decimal(15, 2)
  debt                  Decimal   @default(0)      @db.Decimal(15, 2)
  // All per-player variables are stored in a single JSONB column for atomic updates.
  // The game engine reads this object and writes back modified values each turn.
  variables             Json      @default("{}")
  // Snapshot of last-turn computed results for UI display / history
  lastTurnSnapshot      Json?     @default("{}")
  // Full engine state: activeDecisions, depreciationLedger, legalCases, shareHoldings
  engineState           Json      @default("{}")
  assets                Asset[]

  @@index([playerId])
}

model Asset {
  id        String  @id @default(cuid())
  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  type      String
  value     Decimal  @db.Decimal(15, 2)

  @@index([companyId])
}

// ============================================================
// NOTE: All engine state (active decisions, depreciation ledger,
// legal cases, share holdings) is stored as JSONB in the
// Company.engineState field. Separate tables are not needed
// because the game engine reads/writes the entire state atomically
// each turn.
// ==============================================================

// ============================================================
// Decision library + game config — authoritative at runtime (loaded once by
// GameEngine.loadGameData() at startup, live-reloaded on every admin edit via
// /admin). server/src/data/*.json remain on disk purely as the versioned seed
// source for `npm run db:seed` (see prisma/seed.ts), not as a runtime data path.
// ============================================================

model Decision {
  // == data.decision, promoted to a real column for lookup/uniqueness/admin CRUD.
  name      String   @id
  // The rest of DecisionDefinition (level, description, nature, offensiveAction,
  // excludes, impacts, legalRisks?, competitorsView?, etc.), verbatim.
  data      Json
  updatedAt DateTime @updatedAt

  @@map("decisions")
}

// Named *Row* to avoid colliding with shared/src/gameTypes.ts's `GameConfig` TS type.
// Singleton: always exactly one row, id=1 by convention (no DB-level enforcement,
// same pragmatic style as the rest of this schema).
model GameConfigRow {
  id                   Int      @id @default(1)
  gameSettings         Json
  playerStartingValues Json
  adminVariables       Json
  updatedAt            DateTime @updatedAt

  @@map("game_config")
}

// The pure, scalar, named-input math formulas from FORMULAS.md (§2-§7) — e.g.
// "competitiveness", "netProfit". Admin-editable expression text, evaluated by
// server/src/engine/formulaEngine.ts (a safe hand-rolled parser, no eval/Function/vm).
// The key set is fixed — no create/delete via /admin, since each key is referenced
// by name at a specific calcEngine.ts call site GameLoop hard-depends on; only the
// expression text is editable. Everything procedural/order-dependent in FORMULAS.md
// (execution phases, depreciation ledger iteration, bankruptcy waterfall, FIFO
// tie-breaking) stays as TypeScript, not represented here — see CLAUDE.md.
model Formula {
  key         String   @id
  expression  String
  description String
  updatedAt   DateTime @updatedAt

  @@map("formulas")
}

// Durable lawsuit lifecycle log for the game-timeline replay/spectator feature — the
// live `LegalCaseData` inside Company.engineState.legalCases only survives one extra
// turn past its own resolution (see gameLoop.ts's Step 7 pruning / CLAUDE.md), so it
// can't answer "every lawsuit filed/resolved across the whole game" on its own. One
// row per case (id == LegalCaseData.id, supplied by the caller, never generated here):
// created the turn it's filed, updated once when it resolves. Deliberately has NO FK
// to Player — only to Room — since a Player/Company row can be deleted later (a
// disconnected player's grace-period expiry) while this row must keep meaning
// something; plaintiff/defendant names are denormalized at write time instead of
// joined live, same "resolve once, persist, never re-join" principle
// BankruptedPlayer.playerName already follows.
model LegalCaseHistory {
  id            String   @id
  roomId        String
  room          Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)
  plaintiffId   String
  plaintiffName String
  defendantId   String
  defendantName String
  decisionName  String
  groundName    String
  description   String
  stakes        Decimal  @db.Decimal(15, 2)
  filedRound    Int
  resolvedRound Int?
  // 'won' | 'lost' | 'settled' | 'cancelled' — mirrors LegalCaseData.verdict
  verdict       String?
  createdAt     DateTime @default(now())

  @@index([roomId])
  @@index([roomId, filedRound])
  @@map("legal_case_history")
}
