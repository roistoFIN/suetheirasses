generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum RoomStatus {
  WAITING
  GAME_PHASE
  AFTERMATH
}

model Room {
  id                String       @id @default(cuid())
  status            RoomStatus   @default(WAITING)
  maxPlayers        Int          @default(4) // See shared/src/index.ts MAX_PLAYERS
  currentPhaseRound Int          @default(1)
  createdAt         DateTime     @default(now())

  players           Player[]

  @@index([status])
  @@index([createdAt])
  @@index([id, currentPhaseRound])
}

model Player {
  id           String     @id @default(cuid())
  name         String
  roomId       String
  room         Room       @relation(fields: [roomId], references: [id], onDelete: Cascade)
  isHost       Boolean    @default(false)
  bankrupt     Boolean    @default(false)
  socketId     String?
  createdAt    DateTime   @default(now())
  companyId    String?    @unique
  company      Company?

  @@index([roomId])
  @@index([roomId, bankrupt])
  @@index([socketId])
}

// ============================================================
// Company — financial & production variables (all stored as JSONB
// for flexibility; the game engine reads/writes them directly).
// Legacy columns (cash, debt) kept for quick queries.
// Engine state (active decisions, depreciation ledger, legal cases,
// share holdings) is stored in the `engineState` JSONB field.
// ============================================================
model Company {
  id                    String    @id @default(cuid())
  playerId              String    @unique
  player                Player    @relation(fields: [playerId], references: [id], onDelete: Cascade)
  cash                  Decimal   @default(100000) @db.Decimal(15, 2)
  debt                  Decimal   @default(0)      @db.Decimal(15, 2)
  // All per-player variables are stored in a single JSONB column for atomic updates.
  // The game engine reads this object and writes back modified values each turn.
  variables             Json      @default("{}")
  // Snapshot of last-turn computed results for UI display / history
  lastTurnSnapshot      Json?     @default("{}")
  // Full engine state: activeDecisions, depreciationLedger, legalCases, shareHoldings
  engineState           Json      @default("{}")
  assets                Asset[]

  @@index([playerId])
}

model Asset {
  id        String  @id @default(cuid())
  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  type      String
  value     Decimal  @db.Decimal(15, 2)

  @@index([companyId])
}

// ============================================================
// NOTE: All engine state (active decisions, depreciation ledger,
// legal cases, share holdings) is stored as JSONB in the
// Company.engineState field. Separate tables are not needed
// because the game engine reads/writes the entire state atomically
// each turn.
// ==============================================================

// ============================================================
// Decision library + game config — authoritative at runtime (loaded once by
// GameEngine.loadGameData() at startup, live-reloaded on every admin edit via
// /admin). server/src/data/*.json remain on disk purely as the versioned seed
// source for `npm run db:seed` (see prisma/seed.ts), not as a runtime data path.
// ============================================================

model Decision {
  // == data.decision, promoted to a real column for lookup/uniqueness/admin CRUD.
  name      String   @id
  // The rest of DecisionDefinition (level, description, nature, offensiveAction,
  // excludes, impacts, legalRisks?, competitorsView?, etc.), verbatim.
  data      Json
  updatedAt DateTime @updatedAt

  @@map("decisions")
}

// Named *Row* to avoid colliding with shared/src/gameTypes.ts's `GameConfig` TS type.
// Singleton: always exactly one row, id=1 by convention (no DB-level enforcement,
// same pragmatic style as the rest of this schema).
model GameConfigRow {
  id                   Int      @id @default(1)
  gameSettings         Json
  playerStartingValues Json
  adminVariables       Json
  updatedAt            DateTime @updatedAt

  @@map("game_config")
}

// The pure, scalar, named-input math formulas from FORMULAS.md (§2-§7) — e.g.
// "competitiveness", "netProfit". Admin-editable expression text, evaluated by
// server/src/engine/formulaEngine.ts (a safe hand-rolled parser, no eval/Function/vm).
// The key set is fixed — no create/delete via /admin, since each key is referenced
// by name at a specific calcEngine.ts call site GameLoop hard-depends on; only the
// expression text is editable. Everything procedural/order-dependent in FORMULAS.md
// (execution phases, depreciation ledger iteration, bankruptcy waterfall, FIFO
// tie-breaking) stays as TypeScript, not represented here — see CLAUDE.md.
model Formula {
  key         String   @id
  expression  String
  description String
  updatedAt   DateTime @updatedAt

  @@map("formulas")
}
