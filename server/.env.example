# Database
DATABASE_URL="postgresql://stita:stita_password@localhost:5432/stita_db"

# Server
PORT=3001
NODE_ENV=development

# Client URL (for CORS)
CLIENT_URL=http://localhost:5173

# Local LLM (llama.cpp server) for AI-generated annual report text.
# Run `docker-compose up -d llm` for local (non-Docker) `npm run dev` workflows.
# Optional — falls back to static text from game_engine.json if unreachable.
LLM_URL=http://localhost:8080

# Admin portal (/admin on the client) — a single shared-secret token, sent as the
# x-admin-token header. Unset = admin API disabled (fails closed). No default —
# set your own before using the admin portal.
ADMIN_TOKEN=
